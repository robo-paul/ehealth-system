{
  "name": "ehealth-backend",
  "version": "1.0.0",
  "description": "Backend for Electronic Health System with Fingerprint Authentication",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:backup": "node scripts/backup.js",
    "sensor:test": "node scripts/testSensor.js",
    "create-admin": "node scripts/createMasterAdmin.js",
    "check-role": "node scripts/checkRole.js",
    "fix-admin": "node scripts/fixMasterAdmin.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^6.7.0",
    "express-validator": "^6.15.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "serialport": "^10.5.0",
    "sqlite3": "^5.1.7",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.1",
    "better-sqlite3": "^12.9.0",
    "eslint": "^8.39.0",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3"
  }
}
